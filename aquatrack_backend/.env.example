# Environment Settings
ENVIRONMENT=development

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=aquatrack_user
DB_PASSWORD=aquatrack_password
DB_NAME=aquatrack_db

# Security Settings - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Integration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Object storage (Cloudflare R2) — durable scan-image storage in production.
# Leave blank for local dev (images fall back to ./uploads, which is fine
# locally but ephemeral on Railway). Set all four in production.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=aquatrack-scans

# App Settings
DEFAULT_DAILY_GOAL_ML=2000
MAX_DAILY_GOAL_ML=5000
MIN_DAILY_GOAL_ML=1000